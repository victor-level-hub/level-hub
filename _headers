# Netlify headers — v2.57.18
# O Hub é um único index.html que muda a cada deploy. Sem isto, o navegador/CDN
# pode servir uma versão ANTIGA em cache (causa de "fix não aplica / hard-refresh
# não pega"). Forçamos revalidação do HTML a cada carga; assets versionados podem cachear.
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate
# v2.72.0: CSS extraído do index.html. Sem versão no nome → revalidar a cada carga
# (mesma política do HTML), pra um deploy de CSS aplicar na hora, sem cache stale.
/assets/css/level.css
  Cache-Control: public, max-age=0, must-revalidate
# v2.72.1: módulos JS extraídos do index.html (ui/icon, ui/motion, …). Sem versão no
# nome → revalidar a cada carga (mesma política do HTML), pra não servir JS stale.
/assets/js/*
  Cache-Control: public, max-age=0, must-revalidate
# v2.79.0: ilha de mapas interativos (HTML shell + app.js + vendor/react + módulos +
# map.css). Sem versão no nome → revalidar a cada carga, pra não servir a ilha stale.
/maps-interactive/*
  Cache-Control: public, max-age=0, must-revalidate
